# ============================================================
# AI Fashion Designer — Environment Variables Template
# ============================================================
# Copy this file to .env and fill in your actual values
# cp .env.example .env
# ============================================================

# ---- Database ----
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/fashionai
DATABASE_URL_SYNC=postgresql://postgres:postgres@localhost:5432/fashionai

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0

# ---- Qdrant Vector DB ----
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=

# ---- Groq (Primary LLM) ----
GROQ_API_KEY=gsk_your_key_here

# ---- Hugging Face ----
HF_API_KEY=hf_your_key_here

# ---- Ollama (Local LLM Fallback) ----
OLLAMA_URL=http://localhost:11434

# ---- Supabase ----
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_anon_key
SUPABASE_JWT_SECRET=your_jwt_secret

# ---- Cloudflare R2 Object Storage ----
R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com
R2_ACCESS_KEY=your_r2_access_key
R2_SECRET_KEY=your_r2_secret_key
R2_BUCKET=fashion-ai-assets

# ---- JWT Authentication ----
JWT_SECRET_KEY=change_this_to_a_64_char_random_hex_string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---- Rate Limiting ----
RATE_LIMIT_PER_USER=30
RATE_LIMIT_PER_IP=100

# ---- Langfuse LLM Observability ----
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ---- PostHog Analytics ----
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ---- Firebase Cloud Messaging ----
FCM_SERVER_KEY=

# ---- Application ----
APP_NAME=AI Fashion Designer
APP_VERSION=1.0.0
DEBUG=true
LOG_LEVEL=INFO
CORS_ORIGINS=["http://localhost:3000","http://localhost:8080","http://localhost:5173"]
